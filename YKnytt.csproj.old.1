<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>YKnytt</RootNamespace>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.Text.Encoding.CodePages" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="YUtil.Math">
      <HintPath>knytt/lib/YUtil.Math.dll</HintPath>
    </Reference>
    <Reference Include="YUtil.Collections">
      <HintPath>knytt/lib/YUtil.Collections.dll</HintPath>
    </Reference>
    <Reference Include="YUtil.Random">
      <HintPath>knytt/lib/YUtil.Random.dll</HintPath>
    </Reference>
    <Reference Include="IniParser">
      <HintPath>knytt/lib/INIFileParser.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
