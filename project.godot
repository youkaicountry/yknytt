[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="Juni"
2d_physics/layer_2="JuniCollides"
2d_physics/layer_3="Object"
2d_physics/layer_5="NoClimb"
2d_physics/layer_6="Water"
2d_physics/layer_10="WalkersCollide"
2d_physics/layer_11="FlyersCollide"
2d_physics/layer_12="ObjectsCollide"
2d_physics/layer_13="Umbrella"
2d_physics/layer_14="Bullet"
2d_physics/layer_15="ParticleMapping"
2d_physics/windows_native_icon="res://knytt/icons/winicon.ico"

[mono]

project/assembly_name="YKnytt"

[physics]

common/physics_jitter_fix=0.25
common/physics_interpolation=true
common/enable_object_picking=false

[rendering]

textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.47451, 0.47451, 0.47451, 1)
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
